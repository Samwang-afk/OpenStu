{
  "name": "openstu",
  "version": "0.1.0-alpha",
  "description": "Local-first AI learning CLI",
  "type": "module",
  "bin": {
    "openstu": "./src/index.tsx"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun run scripts/build.ts",
    "install:local": "bun run build && bun run scripts/install-local.ts"
  },
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.88",
    "@ai-sdk/google": "3.0.85",
    "@ai-sdk/openai-compatible": "2.0.53",
    "@opentui/core": "^0.4.2",
    "@opentui/solid": "^0.4.2",
    "ai": "6.0.213",
    "officeparser": "^7.2.2",
    "solid-js": "^1.9.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
